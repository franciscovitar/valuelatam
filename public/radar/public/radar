<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Solicitar Acceso — Value Latam Radar</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='6' fill='%2371B8E3'/><text y='22' x='5' font-size='18' font-family='monospace' font-weight='700' fill='%23000'>VR</text></svg>">
  <script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap');

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }
    body {
      font-family: 'IBM Plex Sans', ui-sans-serif, sans-serif;
      font-size: 13px;
      font-weight: 300;
      background: #0E0E0E;
      color: #888;
      -webkit-font-smoothing: antialiased;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 24px;
    }

    .wrap {
      width: 100%;
      max-width: 440px;
    }

    /* HEADER */
    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 40px;
    }
    .brand-mark {
      width: 28px; height: 28px;
      background: #71B8E3;
      border-radius: 4px;
      display: grid; place-items: center;
      color: #000;
      font-family: 'IBM Plex Mono', monospace;
      font-weight: 500;
      font-size: 11px;
      flex: 0 0 28px;
    }
    .brand-name {
      font-family: 'IBM Plex Sans', sans-serif;
      font-weight: 600;
      font-size: 14px;
      color: #E8E8E8;
      letter-spacing: -0.02em;
    }
    .brand-sub {
      font-size: 10px;
      color: #444;
      font-family: 'IBM Plex Mono', monospace;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-top: 1px;
    }

    h1 {
      font-family: 'IBM Plex Sans', sans-serif;
      font-size: 22px;
      font-weight: 600;
      color: #E8E8E8;
      letter-spacing: -0.025em;
      margin-bottom: 6px;
    }
    .subtitle {
      font-size: 12px;
      color: #555;
      margin-bottom: 32px;
      line-height: 1.5;
    }

    /* FORM */
    .form { display: flex; flex-direction: column; gap: 16px; }

    .field { display: flex; flex-direction: column; gap: 5px; }
    .field label {
      font-size: 10px;
      font-weight: 500;
      font-family: 'IBM Plex Mono', monospace;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: #555;
    }
    .field input, .field select {
      height: 38px;
      padding: 0 12px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 4px;
      color: #E8E8E8;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 12px;
      font-weight: 300;
      transition: border 120ms;
      width: 100%;
    }
    .field input::placeholder { color: #333; }
    .field input:focus, .field select:focus {
      outline: none;
      border-color: #71B8E3;
    }
    .field select {
      appearance: none;
      background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='10' height='10' viewBox='0 0 24 24' fill='none' stroke='%23555' stroke-width='2'><polyline points='6 9 12 15 18 9'/></svg>");
      background-repeat: no-repeat;
      background-position: right 10px center;
      padding-right: 28px;
      cursor: pointer;
    }
    .field select option { background: #1a1a1a; }

    .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

    .btn-submit {
      height: 40px;
      background: #71B8E3;
      color: #000;
      border: none;
      border-radius: 4px;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 12px;
      font-weight: 500;
      cursor: pointer;
      transition: opacity 120ms;
      margin-top: 8px;
      letter-spacing: 0.02em;
    }
    .btn-submit:hover { opacity: 0.85; }
    .btn-submit:disabled { opacity: 0.4; cursor: not-allowed; }

    /* ESTADO */
    .estado { display: none; margin-top: 16px; }
    .estado.success {
      padding: 12px 14px;
      border: 1px solid rgba(61,214,140,0.25);
      border-left: 3px solid #3DD68C;
      border-radius: 4px;
      font-size: 12px;
      color: #3DD68C;
      font-family: 'IBM Plex Mono', monospace;
      line-height: 1.5;
    }
    .estado.error {
      padding: 12px 14px;
      border: 1px solid rgba(248,113,113,0.25);
      border-left: 3px solid #F87171;
      border-radius: 4px;
      font-size: 12px;
      color: #F87171;
      font-family: 'IBM Plex Mono', monospace;
    }

    /* INFO */
    .info {
      margin-top: 40px;
      padding-top: 24px;
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    .info-title {
      font-size: 10px;
      font-weight: 500;
      font-family: 'IBM Plex Mono', monospace;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: #444;
      margin-bottom: 12px;
    }
    .info-items { display: flex; flex-direction: column; gap: 8px; }
    .info-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 11px;
      color: #555;
      line-height: 1.4;
    }
    .info-item .dot {
      width: 4px; height: 4px; border-radius: 50%;
      background: #71B8E3;
      flex: 0 0 4px;
      margin-top: 5px;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      font-family: 'IBM Plex Mono', monospace;
      color: #444;
      margin-top: 24px;
      text-decoration: none;
      transition: color 120ms;
    }
    .back-link:hover { color: #71B8E3; }
  </style>
</head>
<body>

<div class="wrap">

  <div class="brand">
    <div class="brand-mark">VR</div>
    <div>
      <div class="brand-name">Value Radar</div>
      <div class="brand-sub">Latam · PyME</div>
    </div>
  </div>

  <h1>Solicitá acceso</h1>
  <p class="subtitle">
    Completá el formulario y te contactamos en menos de 24 horas hábiles para configurar tu cuenta.
  </p>

  <div class="form" id="form">

    <div class="field-row">
      <div class="field">
        <label>Razón Social *</label>
        <input type="text" id="razon-social" placeholder="Acme S.A." required>
      </div>
      <div class="field">
        <label>CUIT *</label>
        <input type="text" id="cuit" placeholder="30-12345678-9" maxlength="13" required>
      </div>
    </div>

    <div class="field-row">
      <div class="field">
        <label>Nombre de contacto *</label>
        <input type="text" id="nombre-contacto" placeholder="Juan García" required>
      </div>
      <div class="field">
        <label>Cargo</label>
        <select id="cargo">
          <option value="">— Seleccioná —</option>
          <option value="Dueño / Socio">Dueño / Socio</option>
          <option value="Director Financiero">Director Financiero</option>
          <option value="Tesorero">Tesorero</option>
          <option value="Contador">Contador</option>
          <option value="Gerente General">Gerente General</option>
          <option value="Otro">Otro</option>
        </select>
      </div>
    </div>

    <div class="field">
      <label>Email corporativo *</label>
      <input type="email" id="email" placeholder="juan@empresa.com.ar" required>
    </div>

    <div class="field-row">
      <div class="field">
        <label>Teléfono / WhatsApp</label>
        <input type="tel" id="telefono" placeholder="+54 11 1234-5678">
      </div>
      <div class="field">
        <label>Facturación anual aprox.</label>
        <select id="facturacion">
          <option value="">— Seleccioná —</option>
          <option value="Menos de $100M">Menos de $100M</option>
          <option value="$100M – $500M">$100M – $500M</option>
          <option value="$500M – $2.000M">$500M – $2.000M</option>
          <option value="Más de $2.000M">Más de $2.000M</option>
        </select>
      </div>
    </div>

    <div class="field">
      <label>¿Cuántas líneas bancarias activas tenés?</label>
      <select id="lineas">
        <option value="">— Seleccioná —</option>
        <option value="1-3">1 a 3 líneas</option>
        <option value="4-10">4 a 10 líneas</option>
        <option value="Más de 10">Más de 10 líneas</option>
      </select>
    </div>

    <button class="btn-submit" onclick="enviarSolicitud()">
      Enviar solicitud →
    </button>

    <div class="estado" id="estado"></div>

  </div>

  <!-- INFO -->
  <div class="info">
    <div class="info-title">¿Qué incluye Value Latam Radar?</div>
    <div class="info-items">
      <div class="info-item"><div class="dot"></div><span>Dashboard consolidado de deuda financiera — todas tus líneas y cuotas en un solo lugar</span></div>
      <div class="info-item"><div class="dot"></div><span>Comparación automática de tus tasas vs el mercado (BADLAR, TAMAR, LECAPs)</span></div>
      <div class="info-item"><div class="dot"></div><span>Flujo de fondos proyectado a 12 meses — cobros, pagos y posición neta</span></div>
      <div class="info-item"><div class="dot"></div><span>Alertas de vencimientos y oportunidades de refinanciación</span></div>
      <div class="info-item"><div class="dot"></div><span>Análisis breakeven inflación para decisiones de tasa fija vs CER</span></div>
    </div>
  </div>

  <a href="index.html" class="back-link">← Volver al inicio</a>

</div>

<script>
  emailjs.init({ publicKey: 'ebYNiyi7kKlM3yb2_' });

  // Formatear CUIT automáticamente
  document.getElementById('cuit').addEventListener('input', function(e){
    let v = e.target.value.replace(/\D/g,'');
    if(v.length > 2 && v.length <= 10) v = v.slice(0,2)+'-'+v.slice(2);
    if(v.length > 11) v = v.slice(0,11)+'-'+v.slice(11);
    e.target.value = v.slice(0,13);
  });

  async function enviarSolicitud(){
    const razonSocial    = document.getElementById('razon-social').value.trim();
    const cuit           = document.getElementById('cuit').value.trim();
    const nombreContacto = document.getElementById('nombre-contacto').value.trim();
    const cargo          = document.getElementById('cargo').value;
    const email          = document.getElementById('email').value.trim();
    const telefono       = document.getElementById('telefono').value.trim();
    const facturacion    = document.getElementById('facturacion').value;
    const lineas         = document.getElementById('lineas').value;

    const estadoEl = document.getElementById('estado');
    const btn      = document.querySelector('.btn-submit');

    // Validación
    if(!razonSocial || !cuit || !nombreContacto || !email){
      estadoEl.className = 'estado error';
      estadoEl.style.display = 'block';
      estadoEl.textContent = 'Completá los campos obligatorios (*)';
      return;
    }
    if(!/^[\w.-]+@[\w.-]+\.\w+$/.test(email)){
      estadoEl.className = 'estado error';
      estadoEl.style.display = 'block';
      estadoEl.textContent = 'El email no parece válido';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Enviando...';
    estadoEl.style.display = 'none';

    const ahora = new Date().toLocaleString('es-AR', { dateStyle:'full', timeStyle:'short' });

    try {
      await emailjs.send('service_00fu2pi', 'template_hnmpfio', {
        to_email:      'mauricio@valuelatam.com',
        to_name:       'Mauricio',
        subject:       `Nueva solicitud de acceso — ${razonSocial}`,
        from_name:     nombreContacto,
        from_email:    email,
        message: `
NUEVA SOLICITUD DE ACCESO — VALUE LATAM RADAR
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Fecha/hora:     ${ahora}

EMPRESA
Razón Social:   ${razonSocial}
CUIT:           ${cuit}
Facturación:    ${facturacion || 'No especificado'}
Líneas activas: ${lineas || 'No especificado'}

CONTACTO
Nombre:         ${nombreContacto}
Cargo:          ${cargo || 'No especificado'}
Email:          ${email}
Teléfono:       ${telefono || 'No especificado'}

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Enviado desde valuelatam.com/radar/solicitud.html
        `.trim()
      });

      estadoEl.className = 'estado success';
      estadoEl.style.display = 'block';
      estadoEl.innerHTML = `
        ✓ Solicitud enviada correctamente.<br><br>
        Te contactamos a <strong>${email}</strong> en las próximas 24 horas hábiles.
      `;
      document.getElementById('form').style.opacity = '0.4';
      document.getElementById('form').style.pointerEvents = 'none';

    } catch(err){
      console.error('EmailJS error:', err);
      estadoEl.className = 'estado error';
      estadoEl.style.display = 'block';
      estadoEl.innerHTML = `Error al enviar. Escribinos directamente a <a href="mailto:mauricio@valuelatam.com" style="color:#71B8E3;">mauricio@valuelatam.com</a>`;
      btn.disabled = false;
      btn.textContent = 'Enviar solicitud →';
    }
  }
</script>
</body>
</html>
